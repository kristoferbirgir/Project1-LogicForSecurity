Protocol: KeyLookup

# Week 4 - Key Lookup Protocol
# A asks idp for the public key of B (photo server)
# A only knows pk(idp) initially
# idp is lowercase = honest trusted constant

Types:
  Agent A, B, idp;
  Function pk, pw, f5;

Knowledge:
  A: A, B, idp, pk(idp), pw(A,idp), f5;
  idp: A, B, idp, pk(idp), pk(B), inv(pk(idp)), pw(A,idp), f5;

Actions:
  A -> idp: {f5, A, B, pw(A,idp)}(pk(idp))
  idp -> A: {f5, A, B, pk(B)}(inv(pk(idp)))

Goals:
  A authenticates idp on f5, A, B, pk(B)